# Development configuration only. Leave these blank for intentional placeholder mode.
# The Storefront token is the browser-safe public token from Shopify, never a secret Admin API credential.
VITE_SHOPIFY_STORE_DOMAIN=
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=
VITE_SHOPIFY_API_VERSION=

# Public production site URL used for canonical URLs and metadata, for example
# https://www.example.com. Leave blank during local development.
VITE_PUBLIC_SITE_URL=

# Cloudflare Pages Function configuration. Set these in Cloudflare Pages only;
# never prefix them with VITE_ or place real delivery values in this file.
# Supported provider: webhook
CONTACT_DELIVERY_PROVIDER=
CONTACT_DELIVERY_WEBHOOK_URL=
# Optional bearer token sent only from the Pages Function to the webhook.
CONTACT_DELIVERY_WEBHOOK_TOKEN=
